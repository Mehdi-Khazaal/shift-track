# Database (Neon PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host/dbname

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_KEY=replace-with-your-admin-registration-key

# Push Notifications (VAPID keys - generate with web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
WEB_PUSH_CONTACT=mailto:admin@yourapp.com

# Server
PORT=3000

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://mehdi-khazaal.github.io,http://localhost:3000,http://localhost:5500
